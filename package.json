{
  "name": "terramap",
  "private": true,
  "version": "0.1.0",
  "description": "TerraMap monorepo: scraper extension + web dashboard",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:ext": "turbo run dev --filter=@terramap/extension",
    "dev:web": "turbo run dev --filter=@terramap/web",
    "dev:dashboard": "turbo run dev --filter=@terramap/dashboard",
    "dev:ext-class": "turbo run dev --filter=@terramap/extension-classic",
    "dev:ext-agent": "turbo run dev --filter=@terramap/extension-agent",
    "build": "turbo run build",
    "compile": "turbo run compile",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.3"
  }
}
